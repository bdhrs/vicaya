# Vicaya ‚Äî local configuration
#
# Copy this file to `.env` (which is gitignored) and edit the values to match
# your setup. All paths support `~` for the home directory.
#
# Recommended: use absolute paths and double-quote every value. That keeps the
# file directly shell-sourceable (`set -a; . ./.env; set +a`). Either way,
# `uv run tools/research_sources.py env` prints the values as eval-able shell
# export lines with `~` already expanded ‚Äî that is the canonical way to get
# VICAYA_* variables into a shell session.

# Your name ‚Äî labels the run-report sync commit (`chore: update runs <name>`).
VICAYA_USER=name

# Obsidian vault ‚Äî the Markdown vault that holds your research notes.
# VICAYA_VAULT_NAME must match the vault name in the Obsidian app
# (used by the Obsidian CLI: `obsidian vault=<name> ...`).
VICAYA_VAULT_NAME=Obsidian
VICAYA_VAULT_PATH=~/Obsidian

# Library folders ‚Äî one or more document trees to index together into a single
# searchable database. Separate multiple paths with | (pipe). Each path may be
# local, external, or server-mounted. A path that contains a Calibre metadata.db
# is recognised automatically: author and tag metadata is prepended to each
# book's FTS text so tag/author searches work through the unified index.
# Leave blank to disable.
VICAYA_LIBRARY_FOLDERS=
# Local SQLite index for fast library-folders search. Keep this outside the repo.
VICAYA_LIBRARY_FOLDERS_INDEX=
# Optional: comma-separated folders to skip during library-folders refresh.
# Leave blank to index everything under VICAYA_LIBRARY_FOLDERS.
VICAYA_LIBRARY_FOLDERS_EXCLUDE=

# CST canon SQLite database ‚Äî path to `tipitaka-translation-data.db`.
# Sourced from the dpd-db project (https://github.com/digitalpalidictionary/dpd-db).
# Leave blank to disable canon search.
VICAYA_CANON_DB=

# DPD database ‚Äî path to `dpd.db` from the dpd-db project.
# Used to resolve CST book codes to human-readable sutta references
# (e.g. `s0202m_mul:97` ‚Üí `MN60 Apa·πá·πáakasutta·πÉ para 97`).
# Leave blank to fall back to the basic book-code label format.
VICAYA_DPD_DB=

# Early Buddhist Connections (EBC) vault ‚Äî read-only reference vault with
# per-sutta overview cards, multiple translator sets, and Chinese ƒÄgama
# parallels. See https://github.com/dhamma-vinaya-connections/early-buddhist-connections
# Used by `get-ebc-overview` and `search-ebc`. Leave blank to disable.
VICAYA_EBC_VAULT_PATH=~/MyFiles/2_Resources/Early Buddhist Connections

# GRETIL Sanskrit corpus ‚Äî path to a local clone of the GRETIL plain-text mirror.
# Clone once with:
#   git clone https://github.com/wujastyk/GRETIL-mirror.git ~/MyFiles/2_Resources/gretil
# Used by `search-sanskrit`. Leave blank to disable Sanskrit source search.
VICAYA_GRETIL_PATH=~/MyFiles/2_Resources/gretil

# SuttaCentral offline archive ‚Äî root of `sc-data` (with `relationship/parallels.json`
# and `sc_bilara_data/`). Sourced from the dpd-db sibling repo, which clones the
# SuttaCentral bilara-data export. Used by `sc-parallels` and `sc-search` for
# cross-school (Chinese ƒÄgama, Sanskrit) lookups. Leave blank to disable.
VICAYA_SC_DATA_PATH=~/MyFiles/3_Active/dpd-db/resources/sc-data

# PDF generation toggle ‚Äî any non-empty value turns it on, leave blank to skip.
# The PDF always lands in a PDF/ subfolder next to the note itself (mirroring the
# note's own vault subfolder, e.g. series notes get their own PDF/ dir); this
# value is not used as the output directory.
VICAYA_PDF_PATH=1

# Cross-check chain ‚Äî pipe-separated `app:model` entries tried in order for the
# Phase 6 second-model review. Each entry is `app:model` where `app` is one of
# `opencode` or `agy`. The helper runs each entry via subprocess and returns the
# first one that succeeds. vicaya does not store any provider API keys itself ‚Äî
# `opencode` and `agy` must already be authenticated out-of-band.
#
# Example, single entry:
#   VICAYA_CROSS_CHECK_CHAIN=opencode:openrouter/deepseek/deepseek-v4-flash
# Example, multiple entries tried in order (pipe-separated, no spaces around `|`):
#   VICAYA_CROSS_CHECK_CHAIN=opencode:openrouter/deepseek/deepseek-v4-flash|agy:Gemini 3.5 Flash (High)
#
# Recommended: use a pro/flagship-tier model, not a free/lite one ‚Äî cross-check
# quality (catching citation and reasoning errors) depends on the reviewing
# model's strength.
#
# Leave blank to disable the cross-check chain entirely (falls back to a
# # SELF_REVIEW: checklist the agent runs on its own synthesis).
VICAYA_CROSS_CHECK_CHAIN=
