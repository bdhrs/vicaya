# Vicaya — local configuration
#
# Copy this file to `.env` (which is gitignored) and edit the values to match
# your setup. All paths support `~` for the home directory.

# User name/role for run-report publishing. `primary` publishes to origin/main;
# any other value publishes to the current branch upstream and appears in commits.
VICAYA_USER=name

# Obsidian vault — the Markdown vault that holds your research notes.
# VICAYA_VAULT_NAME must match the vault name in the Obsidian app
# (used by the Obsidian CLI: `obsidian vault=<name> ...`).
VICAYA_VAULT_NAME=Obsidian
VICAYA_VAULT_PATH=~/Obsidian

# Calibre library — root directory containing `metadata.db`.
# Leave blank to disable Calibre search.
VICAYA_CALIBRE_LIBRARY=~/Calibre Library

# CST canon SQLite database — path to `tipitaka-translation-data.db`.
# Sourced from the dpd-db project (https://github.com/digitalpalidictionary/dpd-db).
# Leave blank to disable canon search.
VICAYA_CANON_DB=

# DPD database — path to `dpd.db` from the dpd-db project.
# Used to resolve CST book codes to human-readable sutta references
# (e.g. `s0202m_mul:97` → `MN60 Apaṇṇakasuttaṃ para 97`).
# Leave blank to fall back to the basic book-code label format.
VICAYA_DPD_DB=

# Early Buddhist Connections (EBC) vault — read-only reference vault with
# per-sutta overview cards, multiple translator sets, and Chinese Āgama
# parallels. See https://github.com/dhamma-vinaya-connections/early-buddhist-connections
# Used by `get-ebc-overview` and `search-ebc`. Leave blank to disable.
VICAYA_EBC_VAULT_PATH=~/MyFiles/2_Resources/Early Buddhist Connections

# GRETIL Sanskrit corpus — path to a local clone of the GRETIL plain-text mirror.
# Clone once with:
#   git clone https://github.com/wujastyk/GRETIL-mirror.git ~/MyFiles/2_Resources/gretil
# Used by `search-sanskrit`. Leave blank to disable Sanskrit source search.
VICAYA_GRETIL_PATH=~/MyFiles/2_Resources/gretil

# SuttaCentral offline archive — root of `sc-data` (with `relationship/parallels.json`
# and `sc_bilara_data/`). Sourced from the dpd-db sibling repo, which clones the
# SuttaCentral bilara-data export. Used by `sc-parallels` and `sc-search` for
# cross-school (Chinese Āgama, Sanskrit) lookups. Leave blank to disable.
VICAYA_SC_DATA_PATH=~/MyFiles/3_Active/dpd-db/resources/sc-data

# PDF output directory — where to save PDF copies of research notes.
# Set to the Vicaya/PDF subfolder inside your vault, or any writable path.
# Leave blank to skip PDF generation.
VICAYA_PDF_PATH=~/MyFiles/Obsidian/Vicaya/PDF
